      "decode": { "format": "raw-string" }
    },
    {
      "match": { "topicFilter": "devices/device-01/senders/tx-1/link-status" },
      "target": { "location": "root/sender-monitors/tx-monitor-01", "property": "linkStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 1, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/senders/tx-1/transmission-status" },
      "target": { "location": "root/sender-monitors/tx-monitor-01", "property": "transmissionStatus", "onUnresolved": "warn" },
