{
  "version": 1,
  "rules": [
    {
      "match": { "topicFilter": "devices/device-01/receivers/rx-1/link-status" },
      "target": { "location": "root/receiver-monitors/rx-monitor-01", "property": "linkStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 1, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/receivers/rx-1/connection-status" },
      "target": { "location": "root/receiver-monitors/rx-monitor-01", "property": "connectionStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 0, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/receivers/rx-1/external-sync-status" },
      "target": { "location": "root/receiver-monitors/rx-monitor-01", "property": "externalSynchronizationStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 0, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/receivers/rx-1/stream-status" },
      "target": { "location": "root/receiver-monitors/rx-monitor-01", "property": "streamStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 0, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/receivers/rx-1/sync-source-id" },
