    {
      "match": { "topicFilter": "devices/device-01/senders/tx-1/essence-status" },
      "target": { "location": "root/sender-monitors/tx-monitor-01", "property": "essenceStatus", "onUnresolved": "warn" },
      "decode": { "format": "raw-number" },
      "transform": [{ "op": "clamp", "min": 0, "max": 3 }]
    },
    {
      "match": { "topicFilter": "devices/device-01/senders/tx-1/sync-source-id" },
      "target": { "location": "root/sender-monitors/tx-monitor-01", "property": "synchronizationSourceId", "onUnresolved": "warn" },
      "decode": { "format": "raw-string" }
