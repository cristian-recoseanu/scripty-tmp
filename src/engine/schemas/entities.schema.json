{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "uce:entities",
  "title": "UCE Entities File",
  "description": "Schema for entities.yaml — a list of EntityDefinitions.",
  "type": "object",
  "required": ["entities"],
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entityDefinition" }
    }
  },
  "$defs": {
    "baseType": {
      "type": "string",
      "enum": ["string", "bool", "numeric", "object"]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "pattern": { "type": "string" },
        "minItems": { "type": "integer", "minimum": 0 },
        "maxItems": { "type": "integer", "minimum": 0 }
      }
    },
    "propertyDef": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/baseType" },
        "is_array": { "type": "boolean" },
        "type_def": { "type": "string" },
        "read_only": { "type": "boolean" },
        "observable": { "type": "boolean" },
        "nullable": { "type": "boolean" },
        "constraints": { "$ref": "#/$defs/constraints" },
        "description": { "type": "string" }
      },
      "if": { "properties": { "type": { "const": "object" } }, "required": ["type"] },
      "then": { "required": ["type_def"] }
    },
    "argDef": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/baseType" },
        "is_array": { "type": "boolean" },
        "type_def": { "type": "string" },
        "description": { "type": "string" }
      },
      "if": { "properties": { "type": { "const": "object" } }, "required": ["type"] },
      "then": { "required": ["type_def"] }
    },
    "returnDef": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "oneOf": [
            { "$ref": "#/$defs/baseType" },
            { "type": "null" }
          ]
        },
        "is_array": { "type": "boolean" },
        "type_def": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "methodDef": {
      "type": "object",
      "required": ["id", "args", "return_value"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/argDef" }
        },
        "return_value": { "$ref": "#/$defs/returnDef" },
        "description": { "type": "string" }
      }
    },
    "entityDefinition": {
      "type": "object",
      "required": ["entity_name", "properties", "methods"],
      "additionalProperties": false,
      "properties": {
        "entity_name": { "type": "string", "minLength": 1 },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/propertyDef" }
        },
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/methodDef" }
        },
        "description": { "type": "string" }
      }
    }
  }
}
