{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "NcBlockMemberDescriptor",
  "title": "NcBlockMemberDescriptor",
  "description": "MS-05-02 §7 block member descriptor.",
  "type": "object",
  "required": ["oid", "constantOid", "classId", "role", "userLabel", "owner", "description", "constraints"],
  "additionalProperties": false,
  "properties": {
    "oid":         { "type": "integer", "minimum": 1 },
    "constantOid": { "type": "boolean" },
    "classId": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1
    },
    "role":        { "type": "string" },
    "userLabel":   { "type": ["string", "null"] },
    "owner":       { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "constraints": { "type": "null" }
  }
}
