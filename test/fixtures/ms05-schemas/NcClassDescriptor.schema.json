{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "NcClassDescriptor",
  "title": "NcClassDescriptor",
  "description": "MS-05-02 class descriptor.",
  "type": "object",
  "required": ["classId", "name", "fixedRole", "description", "properties", "methods", "events"],
  "additionalProperties": false,
  "properties": {
    "classId": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1
    },
    "name":        { "type": "string" },
    "fixedRole":   { "type": ["string", "null"] },
    "description": { "type": "string" },
    "properties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "typeName", "isReadOnly", "isNullable", "isSequence", "isDeprecated", "description", "constraints"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "object",
            "required": ["level", "index"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "index": { "type": "integer", "minimum": 1 }
            }
          },
          "name":         { "type": "string" },
          "typeName":     { "type": ["string", "null"] },
          "isReadOnly":   { "type": "boolean" },
          "isNullable":   { "type": "boolean" },
          "isSequence":   { "type": "boolean" },
          "isDeprecated": { "type": "boolean" },
          "description":  { "type": "string" },
          "constraints":  { "type": "null" }
        }
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "resultDatatype", "parameters", "description", "isDeprecated"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "object",
            "required": ["level", "index"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "index": { "type": "integer", "minimum": 1 }
            }
          },
          "name":           { "type": "string" },
          "resultDatatype": { "type": ["string", "null"] },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "typeName", "isNullable", "isSequence", "description", "constraints"],
              "additionalProperties": false,
              "properties": {
                "name":        { "type": "string" },
                "typeName":    { "type": ["string", "null"] },
                "isNullable":  { "type": "boolean" },
                "isSequence":  { "type": "boolean" },
                "description": { "type": "string" },
                "constraints": { "type": "null" }
              }
            }
          },
          "description":  { "type": "string" },
          "isDeprecated": { "type": "boolean" }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "eventDatatype", "description", "isDeprecated"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "object",
            "required": ["level", "index"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "index": { "type": "integer", "minimum": 1 }
            }
          },
          "name":          { "type": "string" },
          "eventDatatype": { "type": ["string", "null"] },
          "description":   { "type": "string" },
          "isDeprecated":  { "type": "boolean" }
        }
      }
    }
  }
}
